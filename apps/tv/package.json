{
  "name": "@viuwu/tv",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "prebuild:tv": "expo prebuild --platform android --clean",
    "build:preview": "npm run prebuild:tv && cd android && ./gradlew assembleDebug --no-daemon",
    "build:release": "npm run prebuild:tv && cd android && ./gradlew assembleRelease --no-daemon",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@viuwu/brand": "0.1.0",
    "@viuwu/core": "0.1.0",
    "expo": "~56.0.9",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "react": "19.2.3",
    "react-native": "npm:react-native-tvos@0.85.3-0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-svg": "^15.15.4"
  },
  "devDependencies": {
    "@react-native-tvos/config-tv": "^0.1.6",
    "@types/react": "^19.2.17",
    "typescript": "^6.0.3"
  }
}
